# ===========================================
# OpenClaw API Keys（填入你的 Key，格式：变量名=值）
# ===========================================
# 填好后重启 Gateway：openclaw gateway --port 18789
# ===========================================

# Google Gemini（OpenClaw 可用 GOOGLE_API_KEY 或 GEMINI_API_KEY）
GOOGLE_API_KEY=
GEMINI_API_KEY=

# 豆包（OpenClaw 必须用 VOLCANO_ENGINE_API_KEY 这个变量名）
VOLCANO_ENGINE_API_KEY=

# 智谱（OpenClaw 必须用 ZAI_API_KEY 这个变量名）
ZAI_API_KEY=
# OpenAI（OpenClaw 必须用 OPENAI_API_KEY 这个变量名）
OPENAI_API_KEY=